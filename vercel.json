{
  "functions": {
    "api/server.js": {
      "includeFiles": "data.json"
    }
  },
  "rewrites": [
    {
      "source": "/connect/acces",
      "destination": "/api/server.js"
    },
    {
      "source": "/data/register",
      "destination": "/api/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/server.js"
    }
  ]
}
